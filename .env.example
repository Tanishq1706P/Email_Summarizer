# MongoDB Configuration for Email Loading
MONGO_URI=mongodb+srv://<Password>:<username>@cluster0.jhsuu.mongodb.net/?appName=Cluster0
MONGO_DB=inbox
MONGO_COLLECTION=emails

REDIS_URL=url


# Example: MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/
# MONGO_DB=your_database
# MONGO_COLLECTION=your_emails_collection

# Pipeline latency optimizations (optional overrides)
PIPELINE_MAX_WORKERS=8
EVAL_CONFIDENCE_GATE=0.8
EVAL_ENABLED=false

API-KEY=dummy
