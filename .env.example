# API Auth (generate)
API_KEY=$(openssl rand -base64 32 | tr -d '\n')

# Local Docker DBs (auto-init root user)
MONGO_USER=mongo_admin
MONGO_PASS=$(openssl rand -base64 24 | tr -d '\n')
QDRANT_API_KEY=$(openssl rand -base64 32 | tr -d '\n')
REDIS_PASSWORD=dummy_local_pass  # Upstash overrides REDIS_URL

# LLM (your Groq set)
GROQ_API_KEY=your_groq_key

# Redis (Upstash overrides)
REDIS_URL=rediss://your_upstash_user:token@host:port?tls=true  # dashboard

# App
ALLOWED_ORIGINS=https://your-android-app-domain.com,*  # android UA
RENDER=false  # true for Render
RATE_LIMIT=100

# Cloud override (Render/Atlas):
MONGO_URI=mongodb+srv://user:pass@atlas.mongodb.net/db?retryWrites=true&w=majority (Atlas dashboard)
QDRANT_HOST=https://your-cluster.qdrant.io:6333
QDRANT_API_KEY=cloud_key
